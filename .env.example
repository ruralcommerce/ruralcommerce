# Editor Git sync configuration
# Set these values on the production server only.

GIT_PUSH_ENABLED=1
GIT_USERNAME=your-github-username
GIT_TOKEN=your-github-personal-access-token
GIT_PUSH_BRANCH=master
GIT_REMOTE_URL=https://github.com/ruralcommerce/ruralcommerce.git

# publish-only (padrão): só faz push ao clicar em Publicar no editor.
# all-saves: faz push também em rascunho / autosave (mais commits).
GIT_PUSH_STRATEGY=publish-only

# Opcional: autor dos commits feitos pelo editor no servidor (evita "Author identity unknown").
# GIT_COMMIT_NAME=Rural Commerce Editor
# GIT_COMMIT_EMAIL=editor@ruralcommerceglobal.com

# Opcional: usado por npm run sync:saida neste computador (webhook de deploy no host).
# Pode colocar em .env.local na raiz do projeto (o script sync-saida le essa linha automaticamente).
# Exemplo: URL "Deploy hook" do Vercel/Netlify ou do seu painel.
# DEPLOY_WEBHOOK_URL=https://...

# --- VPS (Hetzner): segundo passo apos sync:saida ---
# npm run deploy:servidor  (ou scripts/DeployServidor.bat)
# O dominio no Squarespace nao substitui isso: e so DNS; o deploy e na maquina Hetzner.
# HETZNER_DEPLOY_HOST=123.45.67.89
# HETZNER_DEPLOY_USER=deploy
# HETZNER_DEPLOY_REMOTE_CMD=cd /var/www/ruralcommerce && git fetch origin && git reset --hard origin/master && npm install && npm run build && pm2 restart NOME_DO_PROCESSO
# HETZNER_SSH_PORT=22
# HETZNER_SSH_IDENTITY_FILE=C:/Users/seuusuario/.ssh/id_ed25519

# --- Formulário de contacto (Resend) ---
# Chave API: Resend → API Keys (nunca em git; usar .env.local ou variáveis no servidor).
RESEND_API_KEY=re_xxxxxxxx
# Remetente: endereço no domínio verificado no Resend (ex.: formulario@ruralcommerceglobal.com).
RESEND_FROM_EMAIL=formulario@ruralcommerceglobal.com
# Opcional: limite de upload da biblioteca de media no editor (MB, 5–200; predefinido 50).
# EDITOR_MAX_UPLOAD_MB=50

