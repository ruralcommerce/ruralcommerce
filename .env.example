# Editor Git sync configuration
# Set these values on the production server only.

GIT_PUSH_ENABLED=1
GIT_USERNAME=your-github-username
GIT_TOKEN=your-github-personal-access-token
GIT_PUSH_BRANCH=master
GIT_REMOTE_URL=https://github.com/ruralcommerce/ruralcommerce.git

# publish-only (padrão): só faz push ao clicar em Publicar no editor.
# all-saves: faz push também em rascunho / autosave (mais commits).
GIT_PUSH_STRATEGY=publish-only

# Opcional: usado por npm run sync:saida no seu computador (webhook do deploy).
# DEPLOY_WEBHOOK_URL=https://...
